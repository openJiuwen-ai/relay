{
  "name": "@openjiuwen/relay-web-contracts",
  "version": "1.0.0",
  "type": "module",
  "description": "Plugin web for OfficeClaw extensions.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth.js",
      "types": "./dist/auth.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm clean && tsc",
    "prepare": "tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}

# Use flat node_modules layout (like npm) for Windows compatibility.
# Replaces shamefully-hoist=true — same flat layout but avoids pnpm's
# .pnpm symlink store which breaks Next.js webpack-build on Windows.
node-linker=hoisted

# Reduce peer dependency noise during development
# Review these settings before production deployment
strict-peer-dependencies=false
auto-install-peers=true
resolve-peers-from-workspace-root=true
link-workspace-packages=true
